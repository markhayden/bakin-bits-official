{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": ["bun"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "allowJs": true
  },
  "include": [
    "plugins/**/*.ts",
    "plugins/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "plugins/**/dist/**"
  ]
}
