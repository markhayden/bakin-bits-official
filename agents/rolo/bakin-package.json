{
  "id": "rolo",
  "kind": "agent",
  "name": "Rolo",
  "version": "0.1.0",
  "description": "Video producer agent. Generates video + audio, mixes finished assets.",
  "bakin": "^1.0.0",
  "author": "Made in Wyo",
  "secrets": [
    {
      "name": "RUNWAY_API_KEY",
      "description": "Runway API key used for video generation workflows.",
      "required": true
    },
    {
      "name": "ELEVENLABS_API_KEY",
      "description": "ElevenLabs API key used for sound effects, music, and voice generation.",
      "required": true
    }
  ],
  "agent": {
    "identity": {
      "name": "Rolo",
      "emoji": "🎬"
    },
    "role": "Video producer",
    "dispatchableBy": ["main"],
    "tags": ["creative", "video", "audio"],
    "allowedTools": [
      "bakin_exec_tasks_*",
      "bakin_exec_assets_*",
      "bakin_exec_lesson_search",
      "bakin_exec_get_paths",
      "bakin_exec_log",
      "bakin_exec_heartbeat"
    ],
    "allowedSkills": ["runway", "elevenlabs"]
  },
  "install": {
    "createIfMissing": true,
    "adoptIfExists": true,
    "writeWorkspaceFiles": true,
    "installSkills": true,
    "installWorkflows": true,
    "enableLessons": ["video-pacing"]
  },
  "contributions": {
    "workspaceFiles": [
      "workspace/SOUL.md",
      "workspace/IDENTITY.md",
      "workspace/AGENTS.md",
      "workspace/TOOLS.md"
    ],
    "lessons": [
      "lessons/video-pacing.md",
      "lessons/audio-craft.md"
    ],
    "assets": ["assets/avatar.jpg", "assets/avatar-full.png"]
  }
}
