{
  "id": "rolo",
  "kind": "agent",
  "name": "Rolo",
  "version": "0.6.1",
  "description": "Video producer agent. Generates video + audio, mixes finished assets.",
  "bakin": ">=0.0.1-rc.1",
  "author": "Made in Wyo",
  "secrets": [
    {
      "name": "RUNWAY_API_KEY",
      "description": "Runway API key used for video generation workflows.",
      "required": true
    },
    {
      "name": "ELEVENLABS_API_KEY",
      "description": "ElevenLabs API key used for sound effects, music, and voice generation.",
      "required": true
    }
  ],
  "agent": {
    "identity": {
      "name": "Rolo",
      "emoji": "🎬"
    },
    "role": "Video producer",
    "dispatchableBy": ["main"],
    "tags": ["creative", "video", "audio"],
    "allowedTools": [],
    "allowedSkills": ["runway", "elevenlabs"]
  },
  "install": {
    "createIfMissing": true,
    "adoptIfExists": true,
    "writeWorkspaceFiles": true,
    "installSkills": true,
    "installWorkflows": true,
    "enableLessons": ["video-pacing"]
  },
  "contributions": {
    "workspaceFiles": [
      "workspace/SOUL.md",
      "workspace/IDENTITY.md",
      "workspace/AGENTS.md",
      "workspace/TOOLS.md"
    ],
    "workflowSkills": ["workflow-skills/produce-video.md"],
    "lessons": [
      "lessons/video-pacing.md",
      "lessons/audio-craft.md",
      "lessons/media-rights.md"
    ],
    "assets": ["assets/avatar.webp"]
  }
}
