{
  "id": "patch",
  "kind": "agent",
  "name": "Patch",
  "version": "0.7.0",
  "description": "Developer agent — API integrations, automation, debugging, tool extensions.",
  "bakin": ">=0.0.1-rc.1",
  "author": "Made in Wyo",
  "agent": {
    "identity": {
      "name": "Patch",
      "emoji": "⚙️"
    },
    "role": "Developer agent",
    "dispatchableBy": [
      "main"
    ],
    "allowedTools": [],
    "tags": [
      "dev",
      "automation",
      "tooling"
    ],
    "allowedSkills": [
      "git-isolation"
    ]
  },
  "install": {
    "createIfMissing": true,
    "adoptIfExists": true,
    "writeWorkspaceFiles": true,
    "installSkills": true,
    "installWorkflows": true,
